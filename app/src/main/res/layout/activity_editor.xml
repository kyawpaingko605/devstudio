<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ctp_base">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/ctp_base">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/ctp_mantle">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/ctp_mantle"
                app:titleTextColor="@color/ctp_text"
                app:subtitleTextColor="@color/ctp_subtext0" />

            <View
                android:id="@+id/accent_line"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/ctp_mauve" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tabs_recycler"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/ctp_mantle"
                android:clipToPadding="false"
                android:paddingHorizontal="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ctp_surface0" />

        </LinearLayout>

        <io.github.rosemoe.sora.widget.CodeEditor
            android:id="@+id/code_editor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/ctp_base" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/ctp_mantle">

            <LinearLayout
                android:id="@+id/build_panel_handle"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:background="@color/ctp_crust"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_build_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BUILD OUTPUT"
                    android:textColor="@color/ctp_subtext0"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:fontFamily="monospace" />

                <ImageView
                    android:id="@+id/iv_panel_toggle"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/arrow_up_float"
                    app:tint="@color/ctp_subtext0"
                    android:contentDescription="Toggle build panel" />

            </LinearLayout>

            <ScrollView
                android:id="@+id/build_output_scroll"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/ctp_mantle"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_build_output"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.4"
                    android:padding="10dp"
                    android:textIsSelectable="true"
                    android:textSize="11sp" />

            </ScrollView>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:background="@color/ctp_base">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_files"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:contentDescription="File tree"
                app:backgroundTint="@color/ctp_surface0"
                app:maxImageSize="22dp"
                app:srcCompat="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/ctp_blue"
                app:fabSize="mini" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_ai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:contentDescription="AI Assistant"
                app:backgroundTint="@color/ctp_surface0"
                app:maxImageSize="22dp"
                app:srcCompat="@android:drawable/ic_menu_info_details"
                app:tint="@color/ctp_mauve"
                app:fabSize="mini" />

            <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                android:id="@+id/fab_build"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Build"
                android:textColor="@color/ctp_crust"
                app:backgroundTint="@color/ctp_green"
                app:icon="@android:drawable/ic_media_play"
                app:iconTint="@color/ctp_crust" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="@dimen/file_tree_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/ctp_mantle"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:background="@color/ctp_crust">

            <TextView
                android:id="@+id/tv_project_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/ctp_text"
                android:textSize="13sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:singleLine="true"
                android:fontFamily="monospace"
                android:text="Project" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FILES"
                android:textColor="@color/ctp_subtext0"
                android:textSize="10sp"
                android:letterSpacing="0.1" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/ctp_surface0" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/file_tree_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="@dimen/ai_panel_width"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/ctp_mantle"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:background="@color/ctp_crust">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✦ AI Assistant"
                android:textColor="@color/ctp_mauve"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btn_close_ai"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/ctp_subtext0"
                android:contentDescription="Close AI" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/ctp_surface0" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chat_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingVertical="8dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_fix_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:text="🔧 Fix Code"
                    android:textColor="@color/ctp_text"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/ctp_surface0"
                    app:chipStrokeColor="@color/ctp_surface1"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_explain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:text="💡 Explain"
                    android:textColor="@color/ctp_text"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/ctp_surface0"
                    app:chipStrokeColor="@color/ctp_surface1"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_add_comments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝 Comments"
                    android:textColor="@color/ctp_text"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/ctp_surface0"
                    app:chipStrokeColor="@color/ctp_surface1"
                    app:chipStrokeWidth="1dp" />

            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="@color/ctp_crust">

            <EditText
                android:id="@+id/et_chat_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@color/ctp_surface0"
                android:hint="@string/ai_placeholder"
                android:textColorHint="@color/ctp_overlay0"
                android:imeOptions="actionSend"
                android:inputType="text"
                android:maxLines="3"
                android:minLines="1"
                android:padding="10dp"
                android:textColor="@color/ctp_text"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_send"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="↑"
                android:textColor="@color/ctp_crust"
                android:textSize="18sp"
                app:backgroundTint="@color/ctp_mauve"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
